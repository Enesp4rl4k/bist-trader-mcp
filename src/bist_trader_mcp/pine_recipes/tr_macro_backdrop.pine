//@version=6
// =============================================================================
// TR Macro Backdrop — overlays Turkish macro context on any chart.
// Generated by bist-trader-mcp. Data is embedded at render time; treat as a
// snapshot for the requested as_of date.
//
// Placeholders filled by the MCP at generation time:
//   {{POLICY_RATE_PCT}}   — latest TCMB 1w repo policy rate (e.g. 47.5)
//   {{O_NIGHT_LENDING}}   — overnight lending rate (upper corridor)
//   {{O_NIGHT_BORROWING}} — overnight borrowing rate (lower corridor)
//   {{CPI_YOY_PCT}}       — latest TÜFE annual change
//   {{PPK_DATES_JSON}}    — JSON array of PPK meeting timestamps (ms epoch)
//   {{AS_OF_DATE}}        — YYYY-MM-DD the snapshot was rendered
// =============================================================================
indicator("TR Macro Backdrop (snapshot {{AS_OF_DATE}})", overlay = true)

// --- Macro snapshot constants -----------------------------------------------
policy_rate    = {{POLICY_RATE_PCT}}
upper_corridor = {{O_NIGHT_LENDING}}
lower_corridor = {{O_NIGHT_BORROWING}}
cpi_yoy        = {{CPI_YOY_PCT}}

// --- PPK meeting markers -----------------------------------------------------
// MCP injects an array literal like [1718323200000, 1721001600000, ...]
ppk_times = array.from({{PPK_DATES_JSON}})

is_ppk_day = false
for i = 0 to array.size(ppk_times) - 1
    ts = array.get(ppk_times, i)
    if time == ts or (timeframe.isintraday and math.abs(time - ts) < 86400000)
        is_ppk_day := true

bgcolor(is_ppk_day ? color.new(color.orange, 70) : na, title = "PPK toplantı günü")

// --- Header table ------------------------------------------------------------
var table info = table.new(position.top_right, 2, 5, border_width = 1)
if barstate.islast
    table.cell(info, 0, 0, "TR Macro Snapshot", text_color = color.white, bgcolor = color.new(color.gray, 30))
    table.cell(info, 1, 0, "{{AS_OF_DATE}}",     text_color = color.white, bgcolor = color.new(color.gray, 30))
    table.cell(info, 0, 1, "Policy rate (1w repo)", text_color = color.white)
    table.cell(info, 1, 1, str.tostring(policy_rate, "#.##") + "%", text_color = color.white)
    table.cell(info, 0, 2, "O/N corridor", text_color = color.white)
    table.cell(info, 1, 2,
        str.tostring(lower_corridor, "#.##") + " / " + str.tostring(upper_corridor, "#.##") + "%",
        text_color = color.white)
    table.cell(info, 0, 3, "CPI (YoY)", text_color = color.white)
    table.cell(info, 1, 3, str.tostring(cpi_yoy, "#.##") + "%", text_color = color.white)
    table.cell(info, 0, 4, "PPK markers", text_color = color.white)
    table.cell(info, 1, 4, str.tostring(array.size(ppk_times)) + " dates", text_color = color.white)
