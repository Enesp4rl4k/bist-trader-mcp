//@version=6
// =============================================================================
// TR Foreign Flow — histogram of daily change in foreign ownership ratio for
// a BIST stock. Positive bars = foreign buyers stepping in; negative = exit.
//
// Placeholders filled by the MCP at generation time:
//   {{TICKER}}                — equity code, e.g. "GARAN"
//   {{FOREIGN_PCT_TS_JSON}}   — JSON array of {date, pct_of_freefloat}
//   {{ALERT_DROP_THRESHOLD}}  — alert when daily ΔFO < -X (default 2.0)
//   {{AS_OF_DATE}}            — YYYY-MM-DD snapshot
// =============================================================================
indicator("TR Foreign Flow — {{TICKER}} ({{AS_OF_DATE}})", overlay = false)

alertDropThreshold = {{ALERT_DROP_THRESHOLD}}

// Snapshot series (parallel arrays loaded once on first bar).
var int[]   foDates = array.new<int>(0)
var float[] foPcts  = array.new<float>(0)

if barstate.isfirst
    {{FOREIGN_FLOW_LOADER}}

// --- Per-bar: match this bar to the snapshot --------------------------------
getPctOnBar() =>
    pct = na
    if array.size(foDates) > 0
        for i = 0 to array.size(foDates) - 1
            ts = array.get(foDates, i)
            if ts >= time and ts <= time_close
                pct := array.get(foPcts, i)
                break
    pct

currentPct = getPctOnBar()
prevPct    = currentPct[1]
deltaPct   = nz(currentPct) - nz(prevPct)

plot(deltaPct, title = "ΔForeign %",
     style = plot.style_columns,
     color = deltaPct >= 0 ? color.new(color.teal, 20) : color.new(color.red, 20))

hline(0, "Zero", color = color.gray)

// --- Alert ------------------------------------------------------------------
alertcondition(deltaPct <= -alertDropThreshold,
               title   = "Foreign exit",
               message = "{{TICKER}}: foreign ownership dropped > " +
                         str.tostring(alertDropThreshold) + "% in one session")
